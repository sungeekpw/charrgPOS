# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
ios/
android/
*.orig.*
*.jks
*.p8
*.key
*.mobileprovision

# Keep the release keystore in the project for builds
# (back it up securely — losing it means you can't publish updates)
# android-signing/charrg-release.p12  ← intentionally NOT ignored
*.p12
!android-signing/charrg-release.p12

# Never commit plaintext credential exports
android-signing/.keystore-env

# NexGo AAR (provided separately by NexGo vendor, not redistributable)
attached_assets/*.aar

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo
.vercel

.env
