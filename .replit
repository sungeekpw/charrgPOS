modules = ["nodejs-24", "java-graalvm22.3"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
KEYSTORE_PASS = "CharrgPOS2025Release!"
KEY_ALIAS = "charrg"
KEY_PASS = "CharrgPOS2025Release!"
CHARRG_ENV = "dev"
CHARRG_DEV_URL = "https://dev-api.charrg.com"

[nix]
channel = "stable-25_05"
packages = ["android-tools"]
